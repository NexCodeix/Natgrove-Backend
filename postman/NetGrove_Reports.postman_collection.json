    {
      "name": "Negative Tests",
      "item": [
        {
          "name": "34. Employee Tries Reports Overview (should be 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status is 403', () => pm.response.to.have.status(403));"]
              }
            }
          ],
