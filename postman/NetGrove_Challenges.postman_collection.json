            }
          }
        },
        {
          "name": "21. Admin - Approve Action Log",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\",\n  \"review_note\": \"Nice work!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{challenges_base_url}}/action-logs/{{action_log_id}}/review/",
              "host": ["{{challenges_base_url}}"],
              "path": ["action-logs", "{{action_log_id}}", "review", ""]
            }
          }
        },
        {
          "name": "22. Get Challenge Detail Again (confirm stats updated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var data = pm.response.json();",
                  "pm.test('participant_count is 1', () => pm.expect(data.participant_count).to.eql(1));",
                  "pm.test('goal_progress current is 1', () => pm.expect(data.goal_progress.current).to.eql(1));",
                  "pm.test('actual_co2_saved_kg is greater than 0', () => pm.expect(parseFloat(data.actual_co2_saved_kg)).to.be.above(0));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/{{goal_challenge_id}}/",
              "host": ["{{challenges_base_url}}"],
              "path": ["{{goal_challenge_id}}", ""]
            }
          }
        },
        {
          "name": "23. Admin - Get Challenge Participants",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/{{goal_challenge_id}}/participants/",
              "host": ["{{challenges_base_url}}"],
              "path": ["{{goal_challenge_id}}", "participants", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Archive, Cancel, Delete",
      "item": [
        {
          "name": "24. Archive the Timeline Challenge",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
