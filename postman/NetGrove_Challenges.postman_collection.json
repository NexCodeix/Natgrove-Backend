            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Should Not Be Allowed\",\n  \"challenge_type\": \"OTHER\",\n  \"start_date\": \"2026-08-01T00:00:00Z\",\n  \"end_date\": \"2026-08-15T00:00:00Z\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{challenges_base_url}}/", "host": ["{{challenges_base_url}}"], "path": [""] }
          }
        },
        {
          "name": "30. Employee Tries to Delete a Challenge (should be 403)",
          "event": [
            {
              "listen": "test",
