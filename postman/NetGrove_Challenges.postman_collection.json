{
  "info": {
    "name": "NetGrove - Challenges App",
    "description": "Self-contained: registers its own company admin + employee (reuses the same 'NetGrove Local' environment as the Accounts collection). Registration needs a real email OTP - check the inbox and paste the 4-digit code into the 'Verify Email' request bodies before sending them. Run top-to-bottom.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "1. Register Company + Admin",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company_name\": \"Acme Corp\",\n  \"email_domain\": \"acme.com\",\n  \"admin_full_name\": \"Alice Smith\",\n  \"admin_email\": \"admin@acme.com\",\n  \"admin_password\": \"SuperSecret123\",\n  \"admin_confirm_password\": \"SuperSecret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/register/company/", "host": ["{{base_url}}"], "path": ["register", "company", ""] }
          }
        },
        {
          "name": "2. Verify Email (Admin) - paste code from inbox",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "var data = pm.response.json();",
                  "pm.environment.set('access_token', data.tokens.access);",
                  "pm.environment.set('company_id', data.user.company);",
                  "pm.environment.set('admin_user_id', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@acme.com\",\n  \"code\": \"PASTE_CODE_FROM_EMAIL\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/verify-email/", "host": ["{{base_url}}"], "path": ["verify-email", ""] }
          }
        },
        {
          "name": "3. Create Department",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "var data = pm.response.json();",
                  "pm.environment.set('department_id', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sustainability\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/departments/", "host": ["{{base_url}}"], "path": ["departments", ""] }
          }
        },
        {
          "name": "4. Register Employee",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Bob Employee\",\n  \"email\": \"bob@acme.com\",\n  \"password\": \"SuperSecret123\",\n  \"confirm_password\": \"SuperSecret123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/register/employee/", "host": ["{{base_url}}"], "path": ["register", "employee", ""] }
          }
        },
        {
          "name": "5. Verify Email (Employee) - paste code from inbox",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "var data = pm.response.json();",
                  "pm.environment.set('employee_access_token', data.tokens.access);",
                  "pm.environment.set('employee_id', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bob@acme.com\",\n  \"code\": \"PASTE_CODE_FROM_EMAIL\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/verify-email/", "host": ["{{base_url}}"], "path": ["verify-email", ""] }
          }
        },
        {
          "name": "6. Assign Employee to Department",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"department\": \"{{department_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/employees/{{employee_id}}/role/",
              "host": ["{{base_url}}"],
              "path": ["employees", "{{employee_id}}", "role", ""]
            }
          }
        },
        {
          "name": "7. List Communities (capture company + department community ids)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "var data = pm.response.json();",
                  "var results = data.results || data;",
                  "var companyCommunity = results.find(c => c.scope === 'COMPANY');",
                  "var deptCommunity = results.find(c => c.scope === 'DEPARTMENT');",
                  "if (companyCommunity) pm.environment.set('company_community_id', companyCommunity.id);",
                  "if (deptCommunity) pm.environment.set('department_community_id', deptCommunity.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/communities/", "host": ["{{base_url}}"], "path": ["communities", ""] }
          }
        },
        {
          "name": "8. List Action Catalog - Water Saving (capture an action id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "var data = pm.response.json();",
                  "var results = data.results || data;",
                  "if (results.length) pm.environment.set('action_id_water', results[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/action-catalog/?category=WATER_SAVING",
              "host": ["{{challenges_base_url}}"],
              "path": ["action-catalog", ""],
              "query": [{ "key": "category", "value": "WATER_SAVING" }]
            }
          }
        },
        {
          "name": "9. List Action Catalog - Recycling (capture a second action id)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "var data = pm.response.json();",
                  "var results = data.results || data;",
                  "if (results.length) pm.environment.set('action_id_recycling', results[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/action-catalog/?category=RECYCLING",
              "host": ["{{challenges_base_url}}"],
              "path": ["action-catalog", ""],
              "query": [{ "key": "category", "value": "RECYCLING" }]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Create & Manage Challenges",
      "item": [
        {
          "name": "10. Create Challenge - Timeline Format (company-wide, no actions)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "var data = pm.response.json();",
                  "pm.environment.set('challenge_id', data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Recycling Drive\",\n  \"description\": \"Reduce product wastage by recycling.\",\n  \"how_to_play\": \"Recycle at least one item and log it with a photo.\",\n  \"rules\": \"One log per action per day.\",\n  \"challenge_type\": \"RECYCLING\",\n  \"challenge_format\": \"TIMELINE\",\n  \"start_date\": \"2026-07-01T00:00:00Z\",\n  \"end_date\": \"2026-07-31T00:00:00Z\",\n  \"status\": \"ACTIVE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{challenges_base_url}}/", "host": ["{{challenges_base_url}}"], "path": [""] }
          }
        },
        {
          "name": "11. Create Challenge - Goal Format (actions + department community + prize)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "var data = pm.response.json();",
                  "pm.environment.set('goal_challenge_id', data.id);",
                  "pm.test('estimated_co2_impact_kg is present', () => pm.expect(data.estimated_co2_impact_kg).to.not.be.undefined);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Reuse a Cup Challenge\",\n  \"description\": \"Cut down single-use cup waste as a department.\",\n  \"challenge_type\": \"WATER_SAVING\",\n  \"actions\": [\"{{action_id_water}}\"],\n  \"communities\": [\"{{department_community_id}}\"],\n  \"challenge_format\": \"GOAL\",\n  \"goal_metric\": \"TOTAL_ACTIONS\",\n  \"goal_title\": \"Log 5 water-saving actions\",\n  \"goal_count\": 5,\n  \"start_date\": \"2026-07-01T00:00:00Z\",\n  \"status\": \"ACTIVE\",\n  \"prize_type\": \"VOUCHER\",\n  \"prizes\": [\n    { \"rank\": 1, \"title\": \"Adidas Voucher\", \"description\": \"10% off\" },\n    { \"rank\": 2, \"title\": \"Coffee Shop Voucher\", \"description\": \"Free coffee\" }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{challenges_base_url}}/", "host": ["{{challenges_base_url}}"], "path": [""] }
          }
        },
        {
          "name": "12. List Challenges (Admin - sees all)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{challenges_base_url}}/", "host": ["{{challenges_base_url}}"], "path": [""] }
          }
        },
        {
          "name": "13. List Challenges Filtered by Status=ACTIVE",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/?status=ACTIVE",
              "host": ["{{challenges_base_url}}"],
              "path": [""],
              "query": [{ "key": "status", "value": "ACTIVE" }]
            }
          }
        },
        {
          "name": "14. Get Challenge Detail (Goal Challenge - inspect computed stats)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/{{goal_challenge_id}}/",
              "host": ["{{challenges_base_url}}"],
              "path": ["{{goal_challenge_id}}", ""]
            }
          }
        },
        {
          "name": "15. Update Challenge (edit description)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated: cut down single-use cup waste department-wide this month.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{challenges_base_url}}/{{goal_challenge_id}}/",
              "host": ["{{challenges_base_url}}"],
              "path": ["{{goal_challenge_id}}", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Employee - Join & Log Actions",
      "item": [
        {
          "name": "16. Employee - List Visible Challenges (community-scoped)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{employee_access_token}}" }],
            "url": { "raw": "{{challenges_base_url}}/", "host": ["{{challenges_base_url}}"], "path": [""] }
          }
        },
        {
          "name": "17. Employee - Join Goal Challenge",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{employee_access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/{{goal_challenge_id}}/join/",
