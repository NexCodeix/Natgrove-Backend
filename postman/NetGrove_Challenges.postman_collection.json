                { "key": "caption", "value": "Reused my cup at the office kitchen.", "type": "text" },
                { "key": "proof_image", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{challenges_base_url}}/{{goal_challenge_id}}/log-action/",
              "host": ["{{challenges_base_url}}"],
              "path": ["{{goal_challenge_id}}", "log-action", ""]
            }
          }
        },
        {
          "name": "19. Employee - My Participations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{employee_access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/my-participations/",
              "host": ["{{challenges_base_url}}"],
              "path": ["my-participations", ""]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Review Submissions",
      "item": [
        {
          "name": "20. Admin - Review Queue for Goal Challenge (pending logs)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": {
              "raw": "{{challenges_base_url}}/{{goal_challenge_id}}/action-logs/?status=PENDING",
